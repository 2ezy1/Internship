DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/devices_db
JWT_SECRET_KEY=replace-with-strong-random-secret
AUTH_SALT=device-mgmt-salt
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Comma-separated list of allowed frontend origins.
# Example: https://app.example.com,https://staging-app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173